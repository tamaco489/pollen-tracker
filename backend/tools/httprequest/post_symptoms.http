@baseUrl = http://localhost:18080

###
# POST /symptoms — 正常系: 全フィールド指定
POST {{baseUrl}}/symptoms
Content-Type: application/json

{
  "date": "2026-05-29",
  "sneezing": 3,
  "runny": 2,
  "itchy": 1,
  "pollen_level": 4,
  "took_medication": true,
  "note": "テストメモ"
}

###
# POST /symptoms — 正常系: 境界下限 (各値 1, note 空文字, 服薬なし)
POST {{baseUrl}}/symptoms
Content-Type: application/json

{
  "date": "2026-05-30",
  "sneezing": 1,
  "runny": 1,
  "itchy": 1,
  "pollen_level": 1,
  "took_medication": false,
  "note": ""
}

###
# POST /symptoms — 正常系: 境界上限 (各値 5)
