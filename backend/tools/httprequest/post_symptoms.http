###
# POST /symptoms — 409: 同一日付で重複登録
# 事前に同じ date でレコードが存在している状態で実行する
POST {{baseUrl}}/symptoms
Content-Type: application/json

{
  "date": "2026-05-29",
  "sneezing": 3,
  "runny": 2,
  "itchy": 1,
  "pollen_level": 4,
  "took_medication": true,
  "note": "重複テスト"
}
